{
  "name": "bga-assistant",
  "version": "1.3.2",
  "private": true,
  "description": "Chrome extension — game assistant for Board Game Arena",
  "type": "module",
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "game-log": "node --import tsx/esm scripts/game-log.ts",
    "game-state": "node --import tsx/esm scripts/game-state.ts",
    "package": "node --import tsx/esm scripts/package.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "chrome-types": "^0.1.327",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
